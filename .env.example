# Temporal Cloud
TEMPORAL_HOST_PORT=your-namespace.tmprl.cloud:7233
TEMPORAL_NAMESPACE=your-namespace
TEMPORAL_TLS_CERT=./certs/client.pem
TEMPORAL_TLS_KEY=./certs/client.key

# Claude API
ANTHROPIC_API_KEY=sk-ant-...

# Web Search
BRAVE_SEARCH_API_KEY=

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/ttm_tracker

# Admin Auth
ADMIN_SEED_EMAIL=you@example.com
ADMIN_SEED_PASSWORD=your-secure-password
SESSION_COOKIE_NAME=ttm_session
SESSION_MAX_AGE=604800

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8080/api

# App
PORT=8080
ENVIRONMENT=development
