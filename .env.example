# Temporal Cloud
TEMPORAL_HOST_PORT=your-namespace.tmprl.cloud:7233
TEMPORAL_NAMESPACE=your-namespace
TEMPORAL_TLS_CERT=./certs/client.pem
TEMPORAL_TLS_KEY=./certs/client.key

# Claude API (Phase 3 — agent activities)
ANTHROPIC_API_KEY=sk-ant-...

# Web Search (Phase 3 — agent tools)
BRAVE_SEARCH_API_KEY=

# PostgreSQL (Phase 1B — Railway provides DATABASE_URL automatically)
DATABASE_URL=postgresql://user:password@localhost:5432/ttm_tracker

# Admin Auth (Phase 2)
ADMIN_PASSWORD=your-secure-password

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8080/api

# App
PORT=8080
ENVIRONMENT=development
